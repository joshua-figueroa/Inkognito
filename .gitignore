# Build products
build/
DerivedData/
*.ipa
*.dSYM
*.dSYM.zip

# User-specific Xcode settings
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.xcscmblueprint
*.xccheckout

# Swift Package Manager
.swiftpm/
.build/
Packages/
!revdash-ios/Packages/
# NOTE: Package.resolved IS intentionally committed (locks dep versions).

# CocoaPods (not used, but safe to ignore)
Pods/
*.xcworkspace/xcuserdata

# Carthage (not used)
Carthage/Build/
Carthage/Checkouts

# Accio
Dependencies/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Injected code (HotReloading, InjectionIII)
iOSInjectionProject/

# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries / coverage
*.test
*.out
coverage.txt
coverage.out
coverage.html

# Vendored dependencies — remove the next line if you choose to vendor
vendor/

# Local tmp
tmp/
/tmp


